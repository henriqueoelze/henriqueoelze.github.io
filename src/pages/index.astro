---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { siteContent } from "../data/site";

const allPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const postCounts = {
  en: allPosts.filter((post) => post.data.lang === "en").length,
  pt: allPosts.filter((post) => post.data.lang === "pt").length
};

const previewLimit = 3;
const baseUrl = import.meta.env.BASE_URL;

const fmtDate = (date: Date, lang: "en" | "pt") =>
  new Intl.DateTimeFormat(lang === "en" ? "en-US" : "pt-BR", {
    day: "numeric",
    month: "short",
    year: "numeric"
  }).format(date);
---

<BaseLayout>
  <main class="page-shell">
    <div class="motion-grid"></div>
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <div class="ambient ambient-c"></div>
    <div class="ambient ambient-d"></div>

    <header class="topbar container">
      <a class="brand" href="#home">Henrique Oelze</a>
      <nav class="nav" aria-label="Primary">
        <a href="#story">
          <span data-lang="en">{siteContent.nav.en.story}</span>
          <span data-lang="pt" hidden>{siteContent.nav.pt.story}</span>
        </a>
        <a href="#projects">
          <span data-lang="en">{siteContent.nav.en.projects}</span>
          <span data-lang="pt" hidden>{siteContent.nav.pt.projects}</span>
        </a>
        <a href="#writing">
          <span data-lang="en">{siteContent.nav.en.writing}</span>
          <span data-lang="pt" hidden>{siteContent.nav.pt.writing}</span>
        </a>
        <a href="#contact">
          <span data-lang="en">{siteContent.nav.en.contact}</span>
          <span data-lang="pt" hidden>{siteContent.nav.pt.contact}</span>
        </a>
      </nav>
      <div class="lang-switch" role="group" aria-label="Language selector">
        <button class="lang-button is-active" type="button" data-lang-button="en" aria-pressed="true">EN</button>
        <button class="lang-button" type="button" data-lang-button="pt" aria-pressed="false">PT</button>
      </div>
    </header>

    <section id="home" class="hero container reveal">
      <div class="hero-copy">
        <p class="eyebrow" data-lang="en">{siteContent.hero.eyebrow.en}</p>
        <p class="eyebrow" data-lang="pt" hidden>{siteContent.hero.eyebrow.pt}</p>
        <h1 class="hero-title" data-lang="en">{siteContent.hero.title.en}</h1>
        <h1 class="hero-title" data-lang="pt" hidden>{siteContent.hero.title.pt}</h1>
        <p class="hero-intro" data-lang="en">{siteContent.hero.intro.en}</p>
        <p class="hero-intro" data-lang="pt" hidden>{siteContent.hero.intro.pt}</p>
        <div class="hero-actions">
          <a class="button button-primary" href="#projects">
            <span data-lang="en">{siteContent.hero.primaryCta.en}</span>
            <span data-lang="pt" hidden>{siteContent.hero.primaryCta.pt}</span>
          </a>
          <a class="button button-secondary" href="#writing">
            <span data-lang="en">{siteContent.hero.secondaryCta.en}</span>
            <span data-lang="pt" hidden>{siteContent.hero.secondaryCta.pt}</span>
          </a>
        </div>
      </div>

      <div class="hero-visual">
        <figure class="portrait-card">
          <div class="portrait-halo"></div>
          <img
            class="portrait-image"
            src={`${baseUrl}profile/profile.jpg`}
            alt={siteContent.hero.portraitAlt.en}
            data-alt-en={siteContent.hero.portraitAlt.en}
            data-alt-pt={siteContent.hero.portraitAlt.pt}
          />
          <!-- <figcaption class="portrait-caption">
            <span data-lang="en">{siteContent.hero.portraitCaption.en}</span>
            <span data-lang="pt" hidden>{siteContent.hero.portraitCaption.pt}</span>
          </figcaption> -->
        </figure>

        <aside class="hero-panel">
          <p class="panel-label" data-lang="en">{siteContent.hero.focusLabel.en}</p>
          <p class="panel-label" data-lang="pt" hidden>{siteContent.hero.focusLabel.pt}</p>
          <ul class="signal-list" data-lang="en">
            {siteContent.hero.focusItems.en.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <ul class="signal-list" data-lang="pt" hidden>
            {siteContent.hero.focusItems.pt.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section id="story" class="section container reveal">
      <div class="section-heading">
        <div class="section-divider" aria-hidden="true">
          <span class="section-divider-line"></span>
          <span class="section-divider-core"></span>
          <span class="section-divider-line"></span>
        </div>
        <h2 data-lang="en">{siteContent.story.title.en}</h2>
        <h2 data-lang="pt" hidden>{siteContent.story.title.pt}</h2>
      </div>
      <div class="story-grid">
        <div class="story-copy">
          {siteContent.story.body.en.map((paragraph) => (
            <p data-lang="en">{paragraph}</p>
          ))}
          {siteContent.story.body.pt.map((paragraph) => (
            <p data-lang="pt" hidden>{paragraph}</p>
          ))}
        </div>
        <div class="stats-card">
          {siteContent.story.stats.map((stat) => (
            <div class="stat">
              <strong>{stat.value}</strong>
              <span data-lang="en">{stat.label.en}</span>
              <span data-lang="pt" hidden>{stat.label.pt}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="section container reveal">
      <div class="section-heading">
        <div class="section-divider" aria-hidden="true">
          <span class="section-divider-line"></span>
          <span class="section-divider-core"></span>
          <span class="section-divider-line"></span>
        </div>
        <h2 data-lang="en">{siteContent.projects.title.en}</h2>
        <h2 data-lang="pt" hidden>{siteContent.projects.title.pt}</h2>
        <p class="section-intro" data-lang="en">{siteContent.projects.intro.en}</p>
        <p class="section-intro" data-lang="pt" hidden>{siteContent.projects.intro.pt}</p>
      </div>

      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="project-card-top">
              <p class="project-period" data-lang="en">{project.period.en}</p>
              <p class="project-period" data-lang="pt" hidden>{project.period.pt}</p>
              <h3 data-lang="en">{project.title.en}</h3>
              <h3 data-lang="pt" hidden>{project.title.pt}</h3>
            </div>
            <p data-lang="en">{project.summary.en}</p>
            <p data-lang="pt" hidden>{project.summary.pt}</p>
            <ul class="project-points" data-lang="en">
              {project.highlights.en.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <ul class="project-points" data-lang="pt" hidden>
              {project.highlights.pt.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            {project.link && (
              <a class="text-link" href={project.link} target="_blank" rel="noreferrer">
                <span data-lang="en">{siteContent.common.linkedinReference.en}</span>
                <span data-lang="pt" hidden>{siteContent.common.linkedinReference.pt}</span>
              </a>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="writing" class="section container reveal">
      <div class="section-heading">
        <div class="section-divider" aria-hidden="true">
          <span class="section-divider-line"></span>
          <span class="section-divider-core"></span>
          <span class="section-divider-line"></span>
        </div>
        <h2 data-lang="en">{siteContent.posts.title.en}</h2>
        <h2 data-lang="pt" hidden>{siteContent.posts.title.pt}</h2>
        <p class="section-intro" data-lang="en">{siteContent.posts.intro.en}</p>
        <p class="section-intro" data-lang="pt" hidden>{siteContent.posts.intro.pt}</p>
      </div>

      {allPosts.length > 0 ? (
        <>
          <div class="post-list" data-post-list data-preview-limit={previewLimit}>
            {allPosts.map((post) => (
              <article class="post-card" data-post-card data-post-lang={post.data.lang}>
                <div class="post-meta">
                  <span>{fmtDate(post.data.date, post.data.lang)}</span>
                  <span>{post.data.lang.toUpperCase()}</span>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="post-footer">
                  <div class="tag-row">
                    {post.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                  <a class="text-link" href={`${baseUrl}posts/${post.id}/`}>
                    {post.data.lang === "pt" ? siteContent.posts.readMore.pt : siteContent.posts.readMore.en}
                  </a>
                </div>
              </article>
            ))}
          </div>

          <p class="post-empty" data-post-empty="en" hidden={postCounts.en > 0}>
            {siteContent.posts.empty.en}
          </p>
          <p class="post-empty" data-post-empty="pt" hidden={postCounts.pt > 0}>
            {siteContent.posts.empty.pt}
          </p>

          <div class="section-actions">
            <a class="button button-secondary" href={`${baseUrl}posts/`}>
              <span data-lang="en">{siteContent.posts.viewAll.en}</span>
              <span data-lang="pt" hidden>{siteContent.posts.viewAll.pt}</span>
            </a>
          </div>
        </>
      ) : (
        <>
          <p data-lang="en">{siteContent.posts.empty.en}</p>
          <p data-lang="pt" hidden>{siteContent.posts.empty.pt}</p>
        </>
      )}
    </section>

    <section id="contact" class="section container reveal">
      <div class="section-heading">
        <div class="section-divider" aria-hidden="true">
          <span class="section-divider-line"></span>
          <span class="section-divider-core"></span>
          <span class="section-divider-line"></span>
        </div>
        <h2 data-lang="en">{siteContent.contact.title.en}</h2>
        <h2 data-lang="pt" hidden>{siteContent.contact.title.pt}</h2>
        <p class="section-intro" data-lang="en">{siteContent.contact.intro.en}</p>
        <p class="section-intro" data-lang="pt" hidden>{siteContent.contact.intro.pt}</p>
      </div>

      <div class="contact-grid">
        <a class="contact-card" href="https://www.linkedin.com/in/henriqueoelze/" target="_blank" rel="noreferrer">
          <span data-lang="en">{siteContent.contact.linkedinLabel.en}</span>
          <span data-lang="pt" hidden>{siteContent.contact.linkedinLabel.pt}</span>
          <strong>linkedin.com/in/henriqueoelze</strong>
        </a>
        <a class="contact-card" href="https://github.com/henriqueoelze" target="_blank" rel="noreferrer">
          <span data-lang="en">{siteContent.contact.githubLabel.en}</span>
          <span data-lang="pt" hidden>{siteContent.contact.githubLabel.pt}</span>
          <strong>github.com/henriqueoelze</strong>
        </a>
      </div>
    </section>

    <footer class="footer footer-centered container">
      <p data-lang="en">{siteContent.footer.en}</p>
      <p data-lang="pt" hidden>{siteContent.footer.pt}</p>
    </footer>
  </main>
</BaseLayout>

<script is:inline define:vars={{ postCounts }}>
  const root = document.documentElement;
  const buttons = Array.from(document.querySelectorAll("[data-lang-button]"));
  const localizedNodes = document.querySelectorAll("[data-lang]");
  const postCards = Array.from(document.querySelectorAll("[data-post-card]"));
  const emptyStates = Array.from(document.querySelectorAll("[data-post-empty]"));
  const portraitImage = document.querySelector(".portrait-image");
  const previewList = document.querySelector("[data-post-list]");
  const previewLimit = Number(previewList?.dataset.previewLimit ?? "3");

  const applyPostFilter = (lang) => {
    let visibleCount = 0;

    for (const card of postCards) {
      const isMatch = card.dataset.postLang === lang;
      const shouldShow = isMatch && visibleCount < previewLimit;
      card.hidden = !shouldShow;
      if (shouldShow) visibleCount += 1;
    }

    for (const state of emptyStates) {
      const stateLang = state.dataset.postEmpty;
      state.hidden = stateLang !== lang || postCounts[lang] > 0;
    }
  };

  const switchLanguage = (lang) => {
    root.dataset.lang = lang;

    for (const node of localizedNodes) {
      node.hidden = node.getAttribute("data-lang") !== lang;
    }

    for (const button of buttons) {
      button.classList.toggle("is-active", button.getAttribute("data-lang-button") === lang);
      button.setAttribute("aria-pressed", String(button.getAttribute("data-lang-button") === lang));
    }

    if (portraitImage) {
      portraitImage.alt = lang === "pt" ? portraitImage.dataset.altPt ?? portraitImage.alt : portraitImage.dataset.altEn ?? portraitImage.alt;
    }

    applyPostFilter(lang);
    localStorage.setItem("preferred-lang", lang);
  };

  const savedLang = localStorage.getItem("preferred-lang");
  const initialLang = savedLang === "pt" ? "pt" : "en";
  switchLanguage(initialLang);

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const lang = button.getAttribute("data-lang-button");
      if (lang === "en" || lang === "pt") switchLanguage(lang);
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.18 }
  );

  document.querySelectorAll(".reveal").forEach((node) => observer.observe(node));
</script>
